{
  "format": "page",
  "id": "article",
  "label": "Article",
  "repeatable": true,
  "status": true,
  "json": {
    "Main": {
      "uid": {
        "type": "UID",
        "config": {
          "label": "URL slug",
          "placeholder": "e.g. why-seo-matters"
        }
      },
      "title": {
        "type": "StructuredText",
        "config": {
          "label": "Title",
          "single": "heading1"
        }
      },
      "date": {
        "type": "Date",
        "config": {
          "label": "Published date"
        }
      },
      "author": {
        "type": "Text",
        "config": {
          "label": "Author",
          "placeholder": "e.g. Amy Varga"
        }
      },
      "featured_image": {
        "type": "Image",
        "config": {
          "label": "Featured image",
          "constraint": {
            "width": 1200,
            "height": 400
          },
          "thumbnails": []
        }
      },
      "excerpt": {
        "type": "Text",
        "config": {
          "label": "Excerpt",
          "placeholder": "Short summary for listing card"
        }
      },
      "body": {
        "type": "StructuredText",
        "config": {
          "label": "Body",
          "multi": "paragraph,strong,em,hyperlink,image,embed,preformatted,list-item,o-list-item,heading2,heading3,heading4"
        }
      }
    },
    "SEO & Metadata": {
      "meta_title": {
        "type": "Text",
        "config": {
          "label": "Meta Title",
          "placeholder": "A title of the page used for social media and search engines"
        }
      },
      "meta_description": {
        "type": "Text",
        "config": {
          "label": "Meta Description",
          "placeholder": "A brief summary of the page"
        }
      },
      "meta_image": {
        "type": "Image",
        "config": {
          "label": "Meta Image",
          "constraint": {
            "width": 2400,
            "height": 1260
          },
          "thumbnails": []
        }
      }
    }
  }
}
